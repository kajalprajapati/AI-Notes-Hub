<UserControl x:Class="AINotesHub.WPF.Views.NoteEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AINotesHub.WPF.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border Padding="20"
            Background="White"
            CornerRadius="8">

        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <StackPanel>

                <!-- Header --><!--
                <TextBlock Text="📝 Note Editor"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,15"/>

                --><!-- Title --><!--
                <TextBlock Text="Title"/>

                <TextBox Text="{Binding EditableTitle, Mode=TwoWay}"
                         Height="35"
                         Margin="0,5,0,15"/>

                --><!-- Content --><!--
                <TextBlock Text="Content"/>

                <TextBox Text="{Binding EditableContent, Mode=TwoWay}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="150"
                         Margin="0,5,0,15"/>-->

                <!-- Reminder -->
                <GroupBox Header="🔔 Reminder"
                          Margin="0,10">

                    <StackPanel Margin="10">

                        <CheckBox Content="Enable Reminder"
                                  IsChecked="{Binding IsReminderOn}"
                                  Margin="0,0,0,8"/>

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,5">

                            <TextBlock Text="Date:"
                                       Width="60"/>

                            <DatePicker SelectedDate="{Binding ReminderDate}"
                                        IsEnabled="{Binding ReminderControlsEnabled}"
                                        Width="160"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">

                            <TextBlock Text="Time:"
                                       Width="60"/>

                            <TextBox Text="{Binding ReminderTime}"
                                     IsEnabled="{Binding ReminderControlsEnabled}"
                                     Width="160" materialDesign:HintAssist.Hint="HH:mm"/>

                        </StackPanel>

                        </StackPanel>

                </GroupBox>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,20,0,0">

                    <Button Content="Cancel"
                            Width="80"
                            Margin="0,0,10,0"
                            Command="{Binding CancelCommand}"/>

                    <Button Content="Save"
                            Width="80"
                            Command="{Binding SaveCommand}"/>

                </StackPanel>

            </StackPanel>

        </ScrollViewer>

    </Border>

</UserControl>

<UserControl x:Class="AINotesHub.WPF.Views.HeaderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AINotesHub.WPF.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" Height="100"
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Background="Transparent" >
        <!-- Main Container -->
        <Border
        Height="60" BorderThickness="0" BorderBrush="#9C27B0"
        Background="White"
        Padding="0,0"
        CornerRadius="22" Margin="10,5,10,10"
        VerticalAlignment="Center">

            <!-- Shadow -->
            <Border.Effect>
                <DropShadowEffect
                BlurRadius="20"
                ShadowDepth="0" 
                    Color="#7E57C2"
                Opacity="0.6"/>
            </Border.Effect>

            <Grid Margin="20,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- My Notes -->
                    <ColumnDefinition Width="*"/>
                    <!-- Search bar -->
                    <!-- Add Button -->
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- My Notes -->

                <Grid Grid.Column="0"
      VerticalAlignment="Center">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <!-- Icon -->
                        <ColumnDefinition Width="0"/>
                        <!-- Spacing -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- Text -->
                    </Grid.ColumnDefinitions>


                    <!-- App Icon -->
                    <Image Grid.Column="0"
           Source="/Assets/Images/MyNotes.png"
           Width="50"
           Height="70"
           VerticalAlignment="Center"/>

                    <!-- App Title -->
                    <TextBlock Grid.Column="2"
               FontSize="24"
               FontWeight="SemiBold"
               VerticalAlignment="Center">

        <!--<Run Text="My" Foreground="#FFF8BBD0"/>
        <Run Text="Notes" Foreground="#4E2CA6"/>-->
                        <!--<Run Text="My" Foreground="#FFF8BBD0"/>-->
<!--<Run Text="Notes" Foreground="#FFD1C4E9"/>-->
                        
                        <!--<Run Text="My" Foreground="#FFF8BBD0"/>
<Run Text="Notes" Foreground="#9C27B0"/>-->
                                                <Run Text="My" Foreground="LightGray"/>
<Run Text="Notes" Foreground="#7B1FA2"/>

                    </TextBlock>

                </Grid>

                <!--<TextBlock Grid.Column="0" VerticalAlignment="Center" 
               
               FontSize="24"
               FontWeight="SemiBold">
                    
                
    <Run Text="My" Foreground="#2D2D2D"/>
    <Run Text="Notes" Foreground="#5B6EF5" />
                </TextBlock>-->

                <!-- Search Bar -->
                <Border
                Grid.Column="1"
                Height="42"
                Background="#F8FAFD"
                CornerRadius="20"
                BorderThickness="1"
                BorderBrush="#E2E8F0"
                Padding="0"
                    Margin="40,0" 
                    MinWidth="300" 
MaxWidth="500" 
                    Visibility="{Binding SidebarVM.IsSearchVisible,
             Converter={StaticResource BooleanToVisibilityConverter}}"
                    >

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>

                         <!--Search Icon--> 
                        
                        <TextBlock Visibility="Visible"
                        Grid.Column="0"
                        Text="🔍"
                        FontSize="25"
                        VerticalAlignment="Center" 
                        HorizontalAlignment="Center" Cursor="Hand"/>

                        <!-- Back / Search Icon -->
                        <Button Grid.Column="1"
            Content="←"
            Background="Transparent"
            BorderThickness="0"
            Command="{Binding ExitSearchCommand}"/>

                        <!-- Search Box -->
                        <TextBox
                        Grid.Column="2"
                        FontSize="14" 
                        Padding="2" Margin="3" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
    materialDesign:HintAssist.Hint="Search notes..."
                        Background="Transparent" IsHitTestVisible="True" Foreground="Gray"
                        VerticalContentAlignment="Center"
                        ToolTip="Search Notes" FocusVisualStyle="{x:Null}" BorderBrush="Transparent" BorderThickness="0" >

                        </TextBox>


                        <ComboBox x:Name="SearchTypeComboBox"  
                                  Grid.Column="3" 
                                   Background="Transparent"
        BorderThickness="0" VerticalAlignment="Center" 
                                  ItemsSource="{Binding SearchOptions}"
    SelectedItem="{Binding SelectedSearchOption}"
                                   FocusVisualStyle="{x:Null}">
                            <!--<ComboBoxItem Content="Contains"/>
                            <ComboBoxItem Content="Exact Match"/>
                            <ComboBoxItem Content="Match Case"/>-->
                        </ComboBox>

                        <!-- Clear Button -->
                        <Button
                        Grid.Column="4"
                        Content="❌" 
                        FontSize="12" Foreground="Black"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"/>

                        <!-- Mic Button -->
                        <Button
                        Grid.Column="5"
                        Content="🎤" Foreground="Black"
                        FontSize="12"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"/>

                    </Grid>
                </Border>
                <Button x:Name="AddNoteBtn" 
                        Grid.Column="2" 
                        Command="{Binding OpenAddNotePopupCommand}"
materialDesign:ButtonAssist.CornerRadius="5"
materialDesign:ElevationAssist.Elevation="Dp3"
        Style="{StaticResource PurpleGradientButtonStyle}" 
Height="40" 
                        
Margin="16,10" 
                        
HorizontalAlignment="Left" 
                        
Padding="0">
                    <StackPanel Orientation="Horizontal" Background="Transparent">
                        <materialDesign:PackIcon Kind="NotePlusOutline" Width="24" Height="24" Margin="0,0,5,0"/>
                        <TextBlock Text="Add Note" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>


                </Button>


            </Grid>
        </Border>

    </Grid>

</UserControl>

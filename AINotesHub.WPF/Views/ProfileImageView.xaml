<UserControl x:Class="AINotesHub.WPF.Views.ProfileImageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AINotesHub.WPF.Views"
             xmlns:local1="clr-namespace:AINotesHub.WPF.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" 
             d:DesignWidth="800">
    <UserControl.Resources>
        <!--<local1:HalfConverter x:Key="HalfConverter"/>-->
    </UserControl.Resources>

    <Grid Background="Transparent" Margin="0,5,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <!--<TextBlock Text="PROFILE VIEW"
               FontSize="30"
               Foreground="White"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"/>-->
        <Border CornerRadius="8" 
            Padding="0"
            Background="#EBF3FB"
            Effect="{DynamicResource DropShadowEffect}"
            BorderBrush="{DynamicResource ThemeAccentBrush}"
            BorderThickness="0"
            SnapsToDevicePixels="True" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" >

            <Button Height="57"
            Background="Transparent"
            BorderThickness="0"
            Click="ProfileMenuButton_Click"  HorizontalAlignment="Stretch" VerticalAlignment="Top">
                <Grid >
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Width="32" Background="Transparent" Height="32" VerticalAlignment="Center">
                         <!--//Fallback avatar--> 
                        <Image x:Name="DefaultAvatar"
Source="/Assets/Images/user.png" 
Stretch="UniformToFill"/>

                         <!--Runtime loaded profile--> 
                        <Image x:Name="ProfileImage"
Stretch="UniformToFill"
Visibility="Collapsed"/>
                         <!--hidden until loaded--> 

                    </Grid>

                    <StackPanel Background="Transparent" Grid.Column="1" Margin="12 0 0 0" VerticalAlignment="Top" >

                        <UniformGrid Rows="2" >
                            <TextBlock x:Name="TxtUserName" Text="{Binding Username, Mode=OneWay}"
                           FontWeight="SemiBold" FontSize="12"
                           Foreground="#222"/>

                            <TextBlock x:Name="TxtEmail" FontWeight="Light" Text="{Binding Email, Mode=OneWay}"  FontSize="12"  Margin="0,2,0,0"
Foreground="Black" />
                        </UniformGrid>

                        <TextBlock x:Name="TxtRole"
                           FontSize="12" Visibility="Collapsed"
                           Foreground="#444"/>
                    </StackPanel>

                    <Popup x:Name="ProfilePopup"
Placement="Bottom"
StaysOpen="False"
AllowsTransparency="True">
                        <Border Background="White"
     CornerRadius="10"
     Padding="15"
     Width="220"
     BorderBrush="#DDD"
     BorderThickness="1"
     SnapsToDevicePixels="True"
     >
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.3" />
                            </Border.Effect>
                            <StackPanel>

                                 <!--User details--> 
                                <TextBlock Text="{Binding Username, Mode=OneWay}"
                FontWeight="Bold"
                FontSize="15" />
                                <TextBlock Text="{Binding Email, Mode=OneWay}"
                Foreground="Gray"
                Margin="0,0,0,15" />



                                 <!--Menu Buttons--> 
                                <Button Style="{DynamicResource ProfileMenuButtonStyle}" Margin="0,4,0,4" Padding="8,6">
                                    <Grid VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE771;" FontSize="16" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="Personalization" VerticalAlignment="Center" FontSize="14" />
                                    </Grid>
                                </Button>

                                <Button Style="{DynamicResource ProfileMenuButtonStyle}" Margin="0,4,0,4" Padding="8,6">
                                    <Grid VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE713;" FontSize="16" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="Settings" VerticalAlignment="Center" FontSize="14" />
                                    </Grid>
                                </Button>

                                <Button Style="{DynamicResource ProfileMenuButtonStyle}" Margin="0,4,0,4" Padding="8,6">
                                    <Grid VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE897;" FontSize="16" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="Help" VerticalAlignment="Center" FontSize="14" />
                                    </Grid>
                                </Button>

                                 <!--Logout Button--> 
                                <Button Style="{DynamicResource ProfileMenuButtonStyle}" Click="BtnLogout_Click" Margin="0,4,0,0" Padding="8,6">
                                    <Grid VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE7E8;" FontSize="16" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="Logout" VerticalAlignment="Center" FontSize="14" />
                                    </Grid>
                                </Button>

                            </StackPanel>
                        </Border>
                    </Popup>

                </Grid>
            </Button>
        </Border>
    </Grid>

</UserControl>

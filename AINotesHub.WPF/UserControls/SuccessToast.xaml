<UserControl x:Class="AINotesHub.WPF.UserControls.SuccessToast"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AINotesHub.WPF.UserControls"
             mc:Ignorable="d"  Height="60" Width="300">
    <!--d:DesignHeight="450" d:DesignWidth="800">-->
    <Grid>
        <Border Background="#4CAF50"
            CornerRadius="10"
            Padding="15"
            Opacity="0"
            x:Name="MainBorder">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="✔" FontSize="22" Margin="0,0,10,0"/>
                <TextBlock x:Name="MessageText"
                       Text="Login Successful!"
                       Foreground="White"
                       VerticalAlignment="Center"
                       FontSize="14"
                       FontWeight="SemiBold"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

<Window x:Class="AINotesHub.WPF.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:AINotesHub.WPF"
        mc:Ignorable="d" Background="#FAFAFA" xmlns:chrome="http://schemas.microsoft.com/winfx/2006/xaml/presentation/shell"

        Title="Login" WindowStartupLocation="CenterScreen" Height="450" Width="450">

    <!--<Window.Resources>
    <SolidColorBrush x:Key="WindowTitleColor" Color="#2196F3"/>
    -->
    <!-- Change your color -->
    <!--
    </Window.Resources>-->

    <!--<Window.Background>
        {StaticResource WindowTitleColor}
    </Window.Background>-->
    <Grid Margin="30" HorizontalAlignment="Center" VerticalAlignment="Center" >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!--<Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>-->


        <!-- Title -->
        <!--<TextBlock Text="Welcome Back"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Margin="0 20 0 30"
                   HorizontalAlignment="Center"/>-->

        <!-- Login Form -->

        <TextBox x:Name="txtEmail"
    Style="{StaticResource MaterialDesignOutlinedTextBox}"
    materialDesign:HintAssist.Hint="Username"
    Width="300"
    Margin="0,20,0,10"/>
        <!--<TextBlock Text="Password:" Grid.Row="1" Margin="0,10,0,5"/>-->
        <!--<PasswordBox x:Name="txtPassword" Grid.Row="1" Height="30" Margin="0,30,0,10"/>-->
        <PasswordBox  Grid.Row="1"
    x:Name="txtPassword"
    Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
    materialDesign:HintAssist.Hint="Password"
    materialDesign:HintAssist.IsFloating="True"
    Width="300"
    Margin="0,10,0,20" />
        <!-- Error message -->
        <TextBlock Grid.Row="2" x:Name="txtError"
               Foreground="Red"
               FontSize="14"
               Margin="0,10,0,0"
               TextWrapping="Wrap"
               Visibility="Collapsed"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Center">
            <!-- Login Button -->
            <Button 
        Content="Login"
        Width="160"
        Height="40"
        Margin="0,0,0,10"
        HorizontalAlignment="Center" 
        Style="{StaticResource PurpleGradientButtonStyle}"
        FontSize="16"
        FontWeight="SemiBold"
        Click="BtnLogin_Click"
        Padding="8"/>

            <!-- Remember Me -->
            <StackPanel Orientation="Horizontal" Margin="10,0,10,0" HorizontalAlignment="Center">
                <CheckBox x:Name="RememberMeCheckBox"
                  Content="Remember Me"                  
                    IsChecked="True" 
                    Padding="4"
                  FontSize="14"
                  VerticalAlignment="Center" Style="{StaticResource CustomCheckBoxStyle}" />

            </StackPanel>

        </StackPanel>

        <TextBlock Grid.Row="4" HorizontalAlignment="Center" Margin="0,15,0,0">
    <Run Text="Don't have an account?"/>
    <Hyperlink Click="Hyperlink_Click_Register">
        <Run Text="Register here."/>
    </Hyperlink>
        </TextBlock>

        <!-- Everything else -->
        <StackPanel Grid.Row="5" x:Name="ToastContainer"
 VerticalAlignment="Bottom"
 HorizontalAlignment="Stretch"
 Margin="20"
 Width="300"
 Background="Transparent"/>
    </Grid>
</Window>

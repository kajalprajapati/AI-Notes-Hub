<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style TargetType="ProgressBar" x:Key="RoundedColoredProgressBar">
        <Setter Property="Height" Value="10" />
        <Setter Property="MaxWidth" Value="500" />
        <Setter Property="MinWidth" Value="15" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border
                        Background="#FFE5E5E5"  
                        CornerRadius="3"
                        Height="{TemplateBinding Height}"
                        MaxWidth="{TemplateBinding MaxWidth}">
                        <Grid x:Name="PART_Track" ClipToBounds="true" >
                            <!-- Clip the content to rounded corners -->
                            <Grid.Clip>
                                <RectangleGeometry Rect="0,0,500,15" RadiusX="3" RadiusY="3"/>
                            </Grid.Clip>
                            <Rectangle
                                x:Name="PART_Indicator"
                                Fill="#FF0078D7"    
                                RadiusX="3"
                                RadiusY="3" />
                            <Rectangle
                                x:Name="Indeterminate"
                                Fill="#FF0078D7"
                                RadiusX="3"
                                RadiusY="3" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
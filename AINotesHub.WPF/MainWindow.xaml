                            </StackPanel>


                        </Button>-->

                        <!--ChnageColor testing Code-->
                        <StackPanel Visibility="Collapsed">
                            <Button  Grid.Row="1" Content="Change Color"
            Command="{Binding ChangeColorCommand}"
            Width="140"
            Margin="10"/>
                            <materialDesign:Card
        Width="100"
        Height="20"
        Margin="20"
        Background="{Binding CurrentNotetestingColor}" />
                        </StackPanel>
                        <Grid Grid.Row="0">
                            <!-- Notes Section -->
                            <ScrollViewer  VerticalScrollBarVisibility="Auto" Visibility="{Binding HasNotes,
                     Converter={StaticResource BooleanToVisibilityConverter}}" 
                     Style="{StaticResource ModernScrollViewerStyle}">

                                <!-- Responsive card grid using WrapPanel -->
                                <WrapPanel Background="Transparent" IsHitTestVisible="True" Orientation="Horizontal" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" >
                                    <!--Background="{Binding CardBackground}"-->
                                    <!--Background="{Binding CardBackground, Converter={StaticResource HexToBrushConverter}}"-->
                                    <!--old color of not background #EBF3FB-->
                                    <ItemsControl x:Name="LstNotes" Background="Transparent"  ItemsSource="{Binding Notes}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <materialDesign:Card Margin="16" Width="300"
        Height="220"
MinWidth="260"
MaxWidth="340"
Padding="18" 
Background="{Binding DataContext.CurrentNoteColor,RelativeSource={RelativeSource AncestorType=Window}}"  UniformCornerRadius="16">
                                                    <materialDesign:Card.Effect>
                                                        <DropShadowEffect BlurRadius="20" Opacity="0.6"  Direction="270"
                                                                      ShadowDepth="0" Color="#7E57C2"/>
                                                    </materialDesign:Card.Effect>
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition/>
                                                            <RowDefinition/>
                                                        </Grid.RowDefinitions>
                                                        <Button Grid.Row="0" Background="Transparent" 
                                                Style="{StaticResource CardClickButton}"
      MinWidth="260"
  MaxWidth="340"
    Padding="0"
    HorizontalAlignment="Stretch"  HorizontalContentAlignment="Stretch"
        VerticalContentAlignment="Stretch"
    Command="{Binding DataContext.OpenNoteCommand,RelativeSource={RelativeSource AncestorType=Window}}"
    CommandParameter="{Binding}">





                                                            <!--Card Content-->

                                                            <Grid Margin="16" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <!-- Category -->
                                                                    <RowDefinition Height="Auto"/>
                                                                    <!-- Title -->
                                                                    <RowDefinition Height="Auto"/>
                                                                    <!-- Content -->
                                                                    <RowDefinition Height="Auto"/>
                                                                    <!-- Separator -->
                                                                    <RowDefinition Height="Auto"/>
                                                                    <!-- Actions -->
                                                                </Grid.RowDefinitions>
                                                                <!--<Border Background="Transparent"
CornerRadius="12" Grid.Row="0"
Padding="4,1"
Margin="0,0,0,8"
HorizontalAlignment="Left"
Visibility="Collapsed">-->
                                                                <!--Category-->
                                                                <TextBlock Visibility="Collapsed"  Grid.Row="0" Text="{Binding Category}" Foreground="#616161" FontWeight="SemiBold" FontSize="13"/>
                                                                <!-- TITLE -->
                                                                <DockPanel Grid.Row="1" Margin="0,0,0,2">
                                                                    <TextBlock Text="{Binding Title}"
FontWeight="Bold"
FontSize="17"
DockPanel.Dock="Left"
VerticalAlignment="Center"/>
                                                                </DockPanel>

                                                                <Separator Grid.Row="2" Margin="0,4,0,8" Opacity="0.15"/>
                                                                <!-- CONTENT -->
                                                                <TextBlock Grid.Row="3" Text="{Binding Content}"
TextWrapping="Wrap"
FontSize="15"
Foreground="#222"
Margin="0,0,0,0"
MaxHeight="90" 
TextTrimming="CharacterEllipsis"/>

                                                                <!--</Border>-->
                                                            </Grid>


                                                            <!--Date-->

                                                        </Button>
                                                        <Grid Grid.Row="1" Margin="0,10,0,0"
      VerticalAlignment="Center">

                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <!-- Checkbox -->
                                                                <ColumnDefinition Width="Auto"/>
                                                                <!-- Star -->
                                                                <ColumnDefinition Width="Auto"/>
                                                                <!-- Important -->
                                                                <ColumnDefinition Width="*"/>
                                                                <!-- Spacer -->
                                                                <ColumnDefinition Width="Auto"/>
                                                                <!-- Time -->
                                                            </Grid.ColumnDefinitions>

                                                            <!-- ☑ Select -->
                                                            <CheckBox Grid.Column="0"
              IsChecked="{Binding IsSelected}"
              VerticalAlignment="Center" 
              Margin="0,0,3,0"/>

                                                            <!-- ⭐ Star -->
                                                            <ToggleButton Grid.Column="1"
                  Style="{StaticResource MaterialDesignFlatToggleButton}"
                  IsChecked="{Binding IsStarred}"
                  Command="{Binding ToggleStarCommand}" 
                  Width="30"
                  Height="30"
                  Padding="0"
                  Margin="0,0,3,0">
                                                                <materialDesign:PackIcon Kind="{Binding IsStarred,
                              Converter={StaticResource StarIconConverter}}"
                                 Foreground="{Binding IsStarred,
                              Converter={StaticResource StarColorConverter}}" />
                                                            </ToggleButton>

                                                            <!-- » Important -->
                                                            <ToggleButton Grid.Column="2"
                                     Style="{StaticResource MaterialDesignFlatToggleButton}"

                  IsChecked="{Binding IsImportant}"
                  Command="{Binding ToggleImportantCommand}"
                  Width="30"
                  Height="30"
                  Padding="0"
                  Margin="0,0,3,0">
                                                                <!--<ToggleButton.Style>
                                                                <Style TargetType="ToggleButton">

                                                                    -->
                                                                <!-- Default: Not Important -->
                                                                <!--
                                                                    <Setter Property="ToolTip" Value="Mark as Important"/>
                                                                    <Setter Property="Foreground" Value="Gray"/>

                                                                    <Style.Triggers>

                                                                        -->
                                                                <!-- Important -->
                                                                <!--
                                                                        <Trigger Property="IsChecked" Value="True">
                                                                            <Setter Property="Foreground" Value="OrangeRed"/>
                                                                            <Setter Property="ToolTip" Value="Marked as Important"/>
                                                                        </Trigger>

                                                                        -->
                                                                <!-- Hover -->
                                                                <!--
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Foreground" Value="DarkOrange"/>
                                                                        </Trigger>

                                                                    </Style.Triggers>
                                                                </Style>

                                                            </ToggleButton.Style>

                                                            <TextBlock FontFamily="Segoe Fluent Icons"
               FontSize="20"
               Text=""  
               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>-->
                                                                <materialDesign:PackIcon Kind="{Binding IsStarred,
                              Converter={StaticResource StarIconConverter}}"
                             Width="20"
                             Height="20">
                                                                    <materialDesign:PackIcon.Style>
                                                                        <Style TargetType="materialDesign:PackIcon">
                                                                            <Setter Property="Foreground" Value="#B0B0B0"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsImportant}" Value="True">
                                                                                    <Setter Property="Foreground" Value="#FFC107"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </materialDesign:PackIcon.Style>
                                                                </materialDesign:PackIcon>
                                                            </ToggleButton>

                                                            <!-- 🕒 Time -->
                                                            <StackPanel Grid.Column="4"
                Orientation="Horizontal"
                VerticalAlignment="Center">
                                                                <!--<materialDesign:PackIcon Kind="ClockOutline"
                                 Width="14"
                                 Height="14"
                                 Margin="0,0,4,0"
                                 Foreground="#757575"/>-->

                                                                <TextBlock Text="{Binding CreatedAt,
                  StringFormat='{}{0:hh:mm tt, ddd d MMM}'}"
                   Foreground="#757575"
                   FontSize="12"/>
                                                            </StackPanel>

                                                        </Grid>
                                                    </Grid>
                                                </materialDesign:Card>
                                                <!--Card Wrapper: CLICKABLE CARD-->

                                                <!--</Border>-->
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </WrapPanel>
                            </ScrollViewer>
                            <!-- Empty message -->
                            <Grid  HorizontalAlignment="Center"
      VerticalAlignment="Center"
 Visibility="{Binding HasNotes,
Converter={StaticResource InverseBoolConverter}}"      MaxWidth="400">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Icon -->
                                <!--<TextBlock Grid.Row="0"
               Text="📝"
               FontSize="50"
               Foreground="#9C27B0"
               HorizontalAlignment="Center"/>-->
                                <!-- Icon -->
                                <materialDesign:PackIcon Grid.Row="0"
                             Kind="NoteOutline"
                             Width="60"
                             Height="60"
                             Foreground="#9C27B0"
                             HorizontalAlignment="Center"/>

                                <!-- Title -->
                                <TextBlock Grid.Row="2"
               Text="No notes yet"
               FontSize="20"
               Foreground="#555555"
               FontWeight="SemiBold"
               HorizontalAlignment="Center"/>

                                <!-- Subtitle -->
                                <TextBlock Grid.Row="4"
               Text="Create your first note"
               FontSize="14"
               Foreground="Gray"
               HorizontalAlignment="Center"/>

                            </Grid>
                        </Grid>

                        <!--<TextBlock Grid.Row="0" Text="{Binding HasNotes}" FontSize="20"/>-->

                        <!-- NOTES LOADER Progressing Ring -->
                        <Grid Grid.Row="1"  Visibility="{Binding IsLoadingNotes,
               Converter={StaticResource BooleanToVisibilityConverter}}">

                            <StackPanel VerticalAlignment="Center" Width="100"
                    HorizontalAlignment="Center" Background="Transparent">


                                <ProgressBar Margin="0,5"
                IsIndeterminate="True" Value="0" Maximum="100" IsHitTestVisible="False"
                Foreground="#5B6EF5"
                 Background="#E5E7EB"/>

                                <TextBlock Text="Loading notes..."
                       FontSize="13" Foreground="#6B7280"
                       
                       HorizontalAlignment="Center"/>
                            </StackPanel>

                        </Grid>


                    </Grid>


                    <!-- Everything else -->

                    <StackPanel x:Name="ToastContainer"
                VerticalAlignment="Top"
                HorizontalAlignment="Right"
                Margin="20"
                Width="300"
                Background="Transparent"/>

                </Grid>

            </Border>

        </Grid>
        <!--</materialDesign:DialogHost.DialogContent>-->

    </materialDesign:DialogHost>
</Window>


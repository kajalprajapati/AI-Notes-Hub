            >
                        <Border Background="#F3E5F5" BorderThickness="2" BorderBrush="#9C27B0"
            CornerRadius="20"
            Width="40"
            Height="40">

                            <materialDesign:PackIcon 
            Kind="Menu"
            Width="22"
            Height="22"
            Foreground="#673AB7"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"/>

                        </Border>

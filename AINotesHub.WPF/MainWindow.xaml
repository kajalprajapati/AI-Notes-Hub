                        <!--
                                    <TextBlock Text="≡"
                               FontSize="26"
                               FontWeight="SemiBold"
                               Foreground="#673AB7"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Top"
                               Margin="0,0,0,0" />
                                </Grid>

                            </ControlTemplate>
                        </Button.Template>-->
                    </Button>



                    <!-- Settings icon -->
                    <Button Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
Style="{StaticResource MaterialDesignIconButton}"
Width="40"
Height="40"
ToolTip="Settings">
                        <materialDesign:PackIcon Kind="Settings"
                     Width="22"
                     Height="22"/>
                    </Button>
                </Grid>
            </Border>

            <!--Converter={StaticResource BooleanToVisibilityConverter}}"-->

                            <ControlTemplate TargetType="Button">
                                <Grid>

                                    <Border Background="Transparent"
                                   
                            CornerRadius="20"
                            Width="40"
                            Height="40"
                            BorderBrush="#888"
                            BorderThickness="0" />

                                    -->

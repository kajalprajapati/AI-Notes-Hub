<Window x:Class="AINotesHub.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AINotesHub.WPF"
        xmlns:converters="clr-namespace:AINotesHub.WPF.Converters"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" 
        xmlns:sys="clr-namespace:System;assembly=System.Runtime" 
        xmlns:views="clr-namespace:AINotesHub.WPF.Views"
        xmlns:vm="clr-namespace:AINotesHub.WPF.ViewModels"
        xmlns:enums="clr-namespace:AINotesHub.WPF.Enums"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen" 
        HorizontalAlignment="Stretch" 
        VerticalAlignment="Stretch"
        Title="AI Notes Hub" 
        Height="450" 
        Width="800" 
        Background="#EBF3FB" 
        Loaded="Window_Loaded" 
        x:Name="RootWindow"
        FontFamily="Segoe UI">

    <Window.Resources>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <converters:StarColorConverter x:Key="StarColorConverter"/>
        <converters:StarIconConverter x:Key="StarIconConverter"/>
        <converters:EnumToBooleanConverter x:Key="EnumToBooleanConverter"/>

        <!-- Theme Dynamic Resources -->
        <!--
        <SolidColorBrush x:Key="ThemePrimaryBrush" Color="#FF1976D2"/>
        <SolidColorBrush x:Key="ThemeSecondaryBrush" Color="#FFBBDEFB"/>
        <SolidColorBrush x:Key="ThemeAccentBrush" Color="#FF64B5F6"/>-->

        <Style x:Key="MaterialDesignFloatingActionMiniAccentButton"
   BasedOn="{StaticResource MaterialDesignFloatingActionMiniButton}"
   TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource MaterialDesignAccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBodyBrush}" />
        </Style>


    </Window.Resources>

    <materialDesign:DialogHost Background="#EBF3FB"
        Identifier="RootDialogHost" DialogTheme="Inherit"
        IsOpen="{Binding IsAddNoteDialogOpen, Mode=TwoWay}">

        <!--<materialDesign:DialogHost.DialogContent>-->
        <materialDesign:DialogHost.DialogContent>
            <materialDesign:ColorZone Mode="Standard">
                <!-- MAIN LAYOUT -->
                <!-- Centering Container -->
                <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                    <!-- Card -->
                    <Border Width="520"
Padding="20"
Background="White"
CornerRadius="12" RenderTransformOrigin="0.5,0.5"
materialDesign:ElevationAssist.Elevation="Dp2">

                        <Border.RenderTransform>
                            <TranslateTransform x:Name="DialogTransform"/>
                        </Border.RenderTransform>

                        <!-- 👉 Your OLD Layout Grid stays here -->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <!-- Header -->
                                <RowDefinition Height="*"/>
                                <!-- Content -->
                                <RowDefinition Height="Auto"/>
                                <!-- Actions -->
                            </Grid.RowDefinitions>

                            <!-- ================= HEADER ================= -->



                            <Grid Grid.Row="0" >

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Add New Note"
                   FontSize="18"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"/>
                                <!--<TextBlock Text="✖" Grid.Column="1"
           FontSize="22"
           Foreground="Black"
           VerticalAlignment="Center"
           HorizontalAlignment="Center"/>-->
                                <!-- CLOSE ICON -->

                                <!--Command="{Binding CloseAddNotePopupCommand}"-->
                                <Button Grid.Column="1"
                Width="32"
                Height="32" 
                Background="Transparent"
                BorderThickness="0">
                                    <!--<Viewbox Width="18" Height="18">-->
                                    <materialDesign:PackIcon Width="20" Height="20" Kind="Close" Foreground="Black"/>
                                    <!--</Viewbox>-->
                                </Button>
                            </Grid>

                            <!-- ================= CONTENT ================= -->
                            <Grid Grid.Row="1" Margin="0,16,0,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <!-- Summary NEW -->
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <!-- Tags NEW -->
                                </Grid.RowDefinitions>

                                <!-- TITLE + AI BUTTON -->
                                <TextBox Grid.Row="0"
                 Text="{Binding NoteTitle, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,12"
                 materialDesign:HintAssist.Hint="Title"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                                <Grid Grid.Row="1" Margin="0,4,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="10"/>
                                        <!-- spacing -->
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- BUTTON -->
                                    <Button Grid.Column="0"
            Content="✨ Generate Title"
            Command="{Binding GenerateTitleCommand}"
            Padding="12,6"
            HorizontalAlignment="Left"/>

                                    <!-- HELPER TEXT -->
                                    <TextBlock Grid.Column="2"
               Text="Auto-generate title from content"
               FontSize="11"
               Foreground="Gray"
               VerticalAlignment="Center"/>

                                </Grid>

                                <!-- CONTENT -->
                                <TextBox Grid.Row="2"
                 Text="{Binding NoteContent, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,12" 
                 materialDesign:HintAssist.Hint="Write your note..."
                 Style="{StaticResource MaterialDesignOutlinedTextBox}" />

                                <TextBox Grid.Row="3"
         Text="{Binding NoteSummary}"
         Margin="0,0,0,12"
         IsReadOnly="True"
         materialDesign:HintAssist.Hint="AI Summary"
         Style="{StaticResource MaterialDesignOutlinedTextBox}" AcceptsReturn="True"
Height="80"
TextWrapping="Wrap"/>

                                <TextBox Grid.Row="4"
         Text="{Binding NoteTags}"
         Margin="0,0,0,12"
         IsReadOnly="True"
         materialDesign:HintAssist.Hint="AI Tags (comma separated)"
         Style="{StaticResource MaterialDesignOutlinedTextBox}" />

                                <!-- CATEGORY -->
                                <TextBox Grid.Row="5"
                 Text="{Binding NoteCategory, UpdateSourceTrigger=PropertyChanged}"
                 materialDesign:HintAssist.Hint="Category"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}" />

                                <!--Command="{Binding GenerateTitleCommand}"-->
                                <!-- 🔥 AI BUTTON -->


                            </Grid>

                            <!-- ================= ACTIONS ================= -->
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- CANCEL -->
                                <!--<Button Grid.Column="1"
                Content="Cancel"  Width="110" Height="38"
                Command="{Binding CloseAddNotePopupCommand}"
                Margin="0,0,12,0"
                Style="{StaticResource MaterialDesignOutlinedButton}" />-->
                                <Button Grid.Column="1"
        Content="Cancel"
        Width="110"
        Height="38"
        Command="{Binding CloseAddNoteDialogCommand}"
        Margin="0,0,12,0"
        Style="{StaticResource MaterialDesignOutlinedButton}" />

                                <!-- SAVE  -->
                                <Button Grid.Column="2"
                Content="Save"   
                Command="{Binding AddNoteCommand}"
                Foreground="White" 
                                        Width="110"
Height="38"
                Padding="26,10"
                BorderThickness="0" 
                                        Style="{StaticResource PurpleGradientButtonStyle}">





                                </Button>
                            </Grid>
                        </Grid>
                    </Border>

                </Grid>
            </materialDesign:ColorZone>
        </materialDesign:DialogHost.DialogContent>

                <StackPanel Orientation="Horizontal" Visibility="Collapsed" Margin="10">
                    <Button Visibility="Collapsed" Content="All"  Tag="All" Margin="5"/>
                    <Button Visibility="Collapsed" Content="Personal"  Tag="Personal" Margin="5"/>
                    <Button Visibility="Collapsed" Content="Work"  Tag="Work" Margin="5"/>
                    <Button Visibility="Collapsed" Content="Study"  Tag="Study" Margin="5"/>

                </StackPanel>
            </Grid>

            <Border Grid.Column="2" Background="#EBF3FB" Margin="20" CornerRadius="15" Padding="5">
                <Grid>
                    <Grid.RowDefinitions>

                        <RowDefinition Height ="Auto"/>
                        <!-- Header -->
                        <RowDefinition Height="Auto"/>
                        <!-- Add Note Section -->
                        <RowDefinition Height="Auto"/>
                        <!-- Filter Section -->
                        <RowDefinition Height="*"/>
                        <!-- Notes Section -->

                        <!--<RowDefinition Height="*"/>-->
                    </Grid.RowDefinitions>

                    <views:HeaderView DataContext="{Binding}"  Grid.Row="0"/>


                    <Grid Grid.Row="0" Visibility="Collapsed"
      Height="50"
      Background="White"
      Margin="10">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Title -->
                        <TextBlock Grid.Row="0" Text="My Notes" FontSize="18" FontWeight="SemiBold"  Foreground="Black"></TextBlock>

                        <!-- Search -->
                        <TextBox Grid.Column="1"
             Width="220"
             Height="32"
             Margin="0,0,15,0"
             VerticalAlignment="Center"
             materialDesign:HintAssist.Hint="Search..."
             Style="{StaticResource MaterialDesignOutlinedTextBox}"
             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>



                    <!--<materialDesign:DialogHost Identifier="AddNoteDialog" IsOpen="{Binding IsAddNoteDialogOpen, Mode=TwoWay}">-->
                    <!-- ADD NOTE DIALOG -->

                    <!--</materialDesign:DialogHost>-->

                    <!-- Filter Section -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="0,10,0,20"
            Background="Transparent" >

                        <!-- Define a ToggleButton Style for all filter buttons -->
                        <!-- 🔹 Add this Resources section ABOVE your buttons -->

                        <RadioButton  x:Name="BtnAll"
                  Content="All" IsChecked="{Binding SelectedFilter, Mode=TwoWay,
                          Converter={StaticResource EnumToBooleanConverter}, 
                          ConverterParameter=All}"
                                      Style="{StaticResource FilterToggleStyle}"
                  MinWidth="100"
                  Margin="5,0"    GroupName="MenuGroup"              Tag="{x:Static enums:NoteFilterType.All}"

                                    Command="{Binding FilterCommand}"
                  CommandParameter="{x:Static enums:NoteFilterType.All}"/>

                        <RadioButton  x:Name="BtnToday"
                  Content="Today" IsChecked="{Binding SelectedFilter, Mode=TwoWay,
                          Converter={StaticResource EnumToBooleanConverter}, 
                          ConverterParameter=Today}"
Tag="{x:Static enums:NoteFilterType.Today}"
                  Style="{StaticResource FilterToggleStyle}"
                  MinWidth="100"
                  Margin="5,0"
                                      GroupName="MenuGroup"
                  CommandParameter="{x:Static enums:NoteFilterType.Today}"
                                        />

                        <RadioButton  x:Name="BtnThisWeek"
                  Content="This Week" GroupName="MenuGroup"
                    Tag="{x:Static enums:NoteFilterType.ThisWeek}"                
Command="{Binding FilterCommand}" IsChecked="{Binding SelectedFilter,Mode=TwoWay, 
                          Converter={StaticResource EnumToBooleanConverter}, 
                          ConverterParameter=ThisWeek}"                     
CommandParameter="{x:Static enums:NoteFilterType.ThisWeek}"
                  Style="{StaticResource FilterToggleStyle}"
                  MinWidth="100"
                  Margin="5,0"/>

                        <RadioButton  x:Name="BtnThisMonth"
                  Content="This Month" GroupName="MenuGroup"
                  Style="{StaticResource FilterToggleStyle}"
                  MinWidth="110" IsChecked="{Binding SelectedFilter, Mode=TwoWay,
                          Converter={StaticResource EnumToBooleanConverter}, 
                          ConverterParameter=ThisMonth}"
                  Tag="{x:Static enums:NoteFilterType.ThisMonth}"                
                  Margin="5,0" 
                   CommandParameter="{x:Static enums:NoteFilterType.ThisMonth}"
                   />

                        <!--Text="{Binding RemainingAiText}"-->
                        <TextBlock
    
    FontSize="12"
    Foreground="Gray"/>
                    </StackPanel>

                    <!--<StackPanel Visibility="Collapsed" Grid.Row="2" HorizontalAlignment="Right">
                        -->

<Window x:Class="AINotesHub.WPF.RegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AINotesHub.WPF" xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d"
        Title="Register" WindowStartupLocation="CenterScreen" MinWidth="360"
        MinHeight="520"
        Width="420"
        Height="600">

    <!-- ScrollViewer keeps the form usable on small screens -->
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/><!-- Email label -->
                <RowDefinition Height="Auto"/><!-- Email input -->
                <RowDefinition Height="8"/><!-- gap -->
                <RowDefinition Height="Auto"/><!-- Username label -->
                <RowDefinition Height="Auto"/><!-- Username input -->
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/><!-- Password label -->
                <RowDefinition Height="Auto"/><!-- Password input -->
                <RowDefinition Height="Auto"/><!-- Strength -->
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/><!-- Confirm label -->
                <RowDefinition Height="Auto"/><!-- Confirm input -->
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/><!-- Error text -->
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/><!-- Register button -->
            </Grid.RowDefinitions>

            <!-- EMAIL -->
            <TextBlock Grid.Row="0" Text="Email" FontWeight="Bold"/>
            <TextBox Grid.Row="1" x:Name="txtEmail" Margin="0,6,0,0" 
                     HorizontalAlignment="Stretch" MinWidth="240"/>

            <!-- USERNAME -->
            <TextBlock Grid.Row="3" Text="Username" FontWeight="Bold"/>
            <TextBox Grid.Row="4" x:Name="txtUsername" Margin="0,6,0,0" 
                     HorizontalAlignment="Stretch"/>

            <!-- PASSWORD -->
            <TextBlock Grid.Row="6" Text="Password" FontWeight="Bold"/>
            <PasswordBox Grid.Row="7" x:Name="txtPassword" Margin="0,6,0,0"
                         PasswordChanged="txtPassword_PasswordChanged"
                         HorizontalAlignment="Stretch" />

            <!-- PASSWORD STRENGTH -->
            <StackPanel Grid.Row="8" Margin="0,8,0,0">
                <ProgressBar x:Name="pbStrength"
                             Height="8"
                             Minimum="0"
                             Maximum="4"
                             Value="0"
                             Background="#EEE"
                             BorderThickness="0"
                             HorizontalAlignment="Stretch"/>
                <TextBlock x:Name="txtStrengthText"
                           Margin="0,6,0,0"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="Gray"
                           Visibility="Collapsed"/>
            </StackPanel>

            <!-- CONFIRM PASSWORD -->
            <TextBlock Grid.Row="10" Text="Confirm Password" FontWeight="Bold"/>
            <PasswordBox Grid.Row="11" x:Name="txtConfirmPassword" Margin="0,6,0,0"
                         PasswordChanged="txtConfirmPassword_PasswordChanged"
                         HorizontalAlignment="Stretch"/>

            <!-- ERROR TEXT -->
            <TextBlock Grid.Row="13"
                       x:Name="txtError"
                       Foreground="Red"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0"
                       FontWeight="Bold" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                       Visibility="Visible"/>

            <!-- REGISTER BUTTON -->
            <StackPanel Grid.Row="15" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnRegister" Style="{StaticResource PurpleGradientButtonStyle}"
                        Content="Register"
                        Width="120"
                        Height="40"
                        Click="BtnRegister_Click"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>

<Window x:Class="AINotesHub.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AINotesHub.WPF"
        xmlns:converters="clr-namespace:AINotesHub.WPF.Converters"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" 
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="AI Notes Hub" Height="450" Width="800" 
        Background="#FFFFFF" Loaded="Window_Loaded"
        FontFamily="Segoe UI">

    <Window.Resources>
        <converters:HexToBrushConverter x:Key="HexToBrushConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>


        <!-- Theme Dynamic Resources -->
        <!--<SolidColorBrush x:Key="ThemePrimaryBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="ThemeSecondaryBrush" Color="#FFF5F5F5"/>
        <SolidColorBrush x:Key="ThemeAccentBrush" Color="#FF1976D2"/>-->
        <SolidColorBrush x:Key="ThemePrimaryBrush" Color="#FF1976D2"/><!-- Buttons, accents -->
        <SolidColorBrush x:Key="ThemeSecondaryBrush" Color="#FFBBDEFB"/><!-- Cards, backgrounds -->
        <SolidColorBrush x:Key="ThemeAccentBrush" Color="#FF64B5F6"/><!-- Highlights -->

        <!--<converters:HexToBrushConverter x:Key="HexToBrushConverter"/>-->
        <Style x:Key="MaterialDesignFloatingActionMiniAccentButton"
   BasedOn="{StaticResource MaterialDesignFloatingActionMiniButton}"
   TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource MaterialDesignAccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBodyBrush}" />
        </Style>
    </Window.Resources>



    <Grid Background="{DynamicResource ThemeSecondaryBrush}" Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/><!-- Theme Panel -->
            <ColumnDefinition/><!-- Notes Panel -->
        </Grid.ColumnDefinitions>

        <Border CornerRadius="15" 
        Background="#FFFFFF"
        Padding="10" Grid.Column="0">
            <Grid>
                <StackPanel Orientation="Vertical">
                    <WrapPanel Orientation="Vertical"
           Margin="10"
           HorizontalAlignment="Center"
           VerticalAlignment="Top">

                        <TextBlock Text="Choose Theme" FontWeight="Bold" FontSize="16" Margin="5"/>
                        <!-- Main Theme Palettes -->
                        <UniformGrid Columns="3" Margin="5" HorizontalAlignment="Center">
                            <!-- Ocean Blue -->
                            <Border CornerRadius="8" Margin="5" MouseLeftButtonUp="ThemePalette_Click" Tag="OceanBlue">
                                <StackPanel Orientation="Horizontal">
                                    <Rectangle Width="25" Height="25" Fill="#FF1976D2"/>
                                    <Rectangle Width="25" Height="25" Fill="#FF64B5F6"/>
                                    <Rectangle Width="25" Height="25" Fill="#FFBBDEFB"/>
                                </StackPanel>
                            </Border>

                            <!-- Sunset Glow -->
                            <Border CornerRadius="8" Margin="5" MouseLeftButtonUp="ThemePalette_Click" Tag="SunsetGlow">
                                <StackPanel Orientation="Horizontal">
                                    <Rectangle Width="25" Height="25" Fill="#FFFF7043"/>
                                    <Rectangle Width="25" Height="25" Fill="#FFFFB74D"/>
                                    <Rectangle Width="25" Height="25" Fill="#FFFFE082"/>
                                </StackPanel>
                            </Border>

                            <!-- Mint Fresh -->
                            <Border CornerRadius="8" Margin="5" MouseLeftButtonUp="ThemePalette_Click" Tag="MintFresh">
                                <StackPanel Orientation="Horizontal">
                                    <Rectangle Width="25" Height="25" Fill="#FF4DB6AC"/>
                                    <Rectangle Width="25" Height="25" Fill="#FF80CBC4"/>
                                    <Rectangle Width="25" Height="25" Fill="#FFB2DFDB"/>
                                </StackPanel>
                            </Border>

                            <!-- Violet Dream -->
                            <Border CornerRadius="8" Margin="5" MouseLeftButtonUp="ThemePalette_Click" Tag="VioletDream">
                                <StackPanel Orientation="Horizontal">
                                    <Rectangle Width="25" Height="25" Fill="#FF8E24AA"/>
                                    <Rectangle Width="25" Height="25" Fill="#FFBA68C8"/>
                                    <Rectangle Width="25" Height="25" Fill="#FFE1BEE7"/>
                                </StackPanel>
                            </Border>

                            <!-- Carbon Dark -->
                            <Border CornerRadius="8" Margin="5" MouseLeftButtonUp="ThemePalette_Click" Tag="CarbonDark">
                                <StackPanel Orientation="Horizontal">
                                    <Rectangle Width="25" Height="25" Fill="#FF212121"/>
                                    <Rectangle Width="25" Height="25" Fill="#FF424242"/>
                                    <Rectangle Width="25" Height="25" Fill="#FFBDBDBD"/>
                                </StackPanel>
                            </Border>

                            <!-- Magenta Pop -->
                            <Border CornerRadius="8" Margin="5" MouseLeftButtonUp="ThemePalette_Click" Tag="MagentaPop">
                                <StackPanel Orientation="Horizontal">
                                    <Rectangle Width="25" Height="25" Fill="#FFD81B60"/>
                                    <Rectangle Width="25" Height="25" Fill="#FFF48FB1"/>
                                    <Rectangle Width="25" Height="25" Fill="#FFFFC1E3"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- Custom Multi-Color Palette -->
                        <TextBlock Text="Custom Colors" FontWeight="Bold" FontSize="14" Margin="5,15,5,5"/>
                        <WrapPanel>
                            <Button Width="25" Height="25" Margin="5" Background="#FFEF5350" BorderBrush="#000" BorderThickness="1" Tag="#FFEF5350" Click="ColorButton_Click"/>
                            <Button Width="25" Height="25" Margin="5" Background="#FFFFA726" BorderBrush="#000" BorderThickness="1" Tag="#FFFFA726" Click="ColorButton_Click"/>
                            <Button Width="25" Height="25" Margin="5" Background="#FF66BB6A" BorderBrush="#000" BorderThickness="1" Tag="#FF66BB6A" Click="ColorButton_Click"/>
                            <Button Width="25" Height="25" Margin="5" Background="#FF42A5F5" BorderBrush="#000" BorderThickness="1" Tag="#FF42A5F5" Click="ColorButton_Click"/>
                            <Button Width="25" Height="25" Margin="5" Background="#FF7E57C2" BorderBrush="#000" BorderThickness="1" Tag="#FF7E57C2" Click="ColorButton_Click"/>
                            <Button Width="25" Height="25" Margin="5" Background="#FFFF80AB" BorderBrush="#000" BorderThickness="1" Tag="#FFFF80AB" Click="ColorButton_Click"/>
                            <Button Width="25" Height="25" Margin="5" Background="#FF212121" BorderBrush="#000" BorderThickness="1" Tag="#FF212121" Click="ColorButton_Click"/>
                        </WrapPanel>


                        <!-- Color selection -->
                    <StackPanel Grid.Column="3" Orientation="Vertical" VerticalAlignment="Center">
                        <Button Width="25" Height="25" Margin="5" Style="{StaticResource MaterialDesignFloatingActionMiniAccentButton}"
Background="#FF90CAF9" BorderBrush="#7C4DFF" BorderThickness="2"
Click="ColorButton_Click" Tag="#FF90CAF9"/>
                        <Button Width="25" Height="25" Margin="5" Style="{StaticResource MaterialDesignFloatingActionMiniAccentButton}"
Background="#FFF48FB1" BorderBrush="#7C4DFF" BorderThickness="2"
Click="ColorButton_Click" Tag="#FFF48FB1"/>
                        <Button Width="25" Height="25" Margin="5" Style="{StaticResource MaterialDesignFloatingActionMiniAccentButton}"
Background="#FFFFF59D" BorderBrush="#7C4DFF" BorderThickness="2"
Click="ColorButton_Click" Tag="#FFFFF59D"/>
                        <Button Width="25" Height="25" Margin="5" Style="{StaticResource MaterialDesignFloatingActionMiniAccentButton}"
Background="#FFA5D6A7" BorderBrush="#7C4DFF" BorderThickness="2"
Click="ColorButton_Click" Tag="#FFA5D6A7"/>

                            


                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!--Background="#F6F8FA"-->
        <Border Grid.Column="1"  CornerRadius="15" Padding="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height ="Auto"/><!-- Header -->
                    <RowDefinition Height="Auto"/><!-- Add Note Section -->
                    <RowDefinition Height="Auto"/><!-- Filter Section -->
                    <RowDefinition Height="*"/><!-- Notes Section -->
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" FontSize="18" FontWeight="SemiBold" Margin="5 5 0 10" Foreground="Black">My Notes</TextBlock>

                <!-- Add New Note Section -->
                <Grid Grid.Row="1" Margin="0 0 0 20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="2*"/>
                        <!--<ColumnDefinition Width="2*"/>-->
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Title -->
                    <TextBox Grid.Column="0" x:Name="TxtTitle" Margin="5"
     materialDesign:HintAssist.Hint="Title" BorderBrush="{DynamicResource ThemeAccentBrush}"
     Style="{StaticResource MaterialDesignOutlinedTextBox}" />

                    <!-- Content -->
                    <TextBox Grid.Column="1" x:Name="TxtContent" Margin="5"
     materialDesign:HintAssist.Hint="Content" BorderBrush="{DynamicResource ThemeAccentBrush}"
     Style="{StaticResource MaterialDesignOutlinedTextBox}" />

                    <!-- Category -->
                    <TextBox Grid.Column="2" x:Name="TxtCategory" Margin="5"
     materialDesign:HintAssist.Hint="Category" BorderBrush="{DynamicResource ThemeAccentBrush}"
     Style="{StaticResource MaterialDesignOutlinedTextBox}" />



                    <!-- Add button -->
                    <Button Visibility="Collapsed" Grid.Column="3" x:Name="BtnAdd" Margin="5"
    Content="Add Note"
    Style="{StaticResource MaterialDesignOutlinedDarkButton}"
    Click="BtnAdd_Click"/>
                </Grid>


                <!-- Filter Section -->
                <StackPanel Grid.Row="2" Orientation="Horizontal"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="0,10,0,20"
            Background="Transparent" >

                    <!-- Define a ToggleButton Style for all filter buttons -->
                    <!-- 🔹 Add this Resources section ABOVE your buttons -->
                 
                    <ToggleButton x:Name="BtnAll"
                  Content="All"
                  Style="{StaticResource MaterialDesignOutlinedButton}"
                  MinWidth="100"
                  Padding="0,0"
                  FontSize="14"
                  Margin="5,0"
                  IsChecked="True"
                  Foreground="Gray"
                  BorderThickness="0"
                  Checked="FilterButton_Checked"
                  Unchecked="FilterButton_Unchecked"/>
                    
                    <ToggleButton x:Name="BtnToday"
                  Content="Today"
                  Style="{StaticResource MaterialDesignOutlinedButton}"
                  MinWidth="100"
                  Padding="0,0"
                  FontSize="14"
                  Margin="5,0"
                  Foreground="Gray" BorderThickness="0" Checked="FilterButton_Checked" />

                    <ToggleButton x:Name="BtnThisWeek"
                  Content="This Week"
                  Style="{StaticResource MaterialDesignOutlinedButton}"
                  MinWidth="100"
                  Padding="0,0"
                  FontSize="14"
                  Margin="5,0" Foreground="Gray" BorderThickness="0" Checked="FilterButton_Checked"/>

                    <ToggleButton x:Name="BtnThisMonth"
                  Content="This Month"
                  Style="{StaticResource MaterialDesignOutlinedButton}"
                  MinWidth="110"
                  Padding="0,0"
                  FontSize="14"
                  Margin="5,0" Foreground="Gray" BorderThickness="0" Checked="FilterButton_Checked"/>
                </StackPanel>

                <StackPanel Grid.Row="2" HorizontalAlignment="Right">
                    <!-- Calendar control -->
                    <DatePicker 
    SelectedDate="{Binding SelectedDate}" 
    Width="200"
    Margin="10"
    Style="{StaticResource MaterialDesignFloatingHintDatePicker}"
    materialDesign:HintAssist.Hint="Select Date" />
                </StackPanel>

                <!-- ADD NOTE CARD -->

                <Grid x:Name="NoteSection" Grid.Row="3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height ="Auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <materialDesign:Card Margin="16" Grid.Row="0"
           MinWidth="260"
           Width="200"
           MaxWidth="340"
                                             MinHeight="150"
           UniformCornerRadius="12"
           
                                             Background="{DynamicResource ThemeSecondaryBrush}"
                         BorderBrush="LightGray"
                         BorderThickness="1"
                         Padding="10"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
           >
                        <materialDesign:Card.Effect>
                            <DropShadowEffect BlurRadius="8" Opacity="0.2" Direction="270" ShadowDepth="4"/>
                        </materialDesign:Card.Effect>
                        <!--Card content-->
                        <Button Background="Transparent"  BorderThickness="0"
HorizontalAlignment="Center" VerticalAlignment="Center"

Click="BtnAdd_Click">
                            <materialDesign:PackIcon Kind="Plus" Width="35" Height="30" Foreground="Gray"/>
                        </Button> 
                    </materialDesign:Card>
                    <!-- Notes Section with Cards -->
                    <ScrollViewer  Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <!-- Responsive card grid using WrapPanel -->
                        <WrapPanel  Orientation="Horizontal" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" >

                            <!--Background="{Binding CardBackground, Converter={StaticResource HexToBrushConverter}}"-->

                            <ItemsControl x:Name="LstNotes" ItemsSource="{Binding Notes}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel IsItemsHost="True" Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <materialDesign:Card Margin="16"
              MinWidth="260"
              MaxWidth="340"
              Padding="18"
              Background="{DynamicResource ThemeSecondaryBrush}"
              UniformCornerRadius="16">
                                            <materialDesign:Card.Effect>
                                                <DropShadowEffect BlurRadius="8" Opacity="0.2" Direction="270" ShadowDepth="4"/>
                                            </materialDesign:Card.Effect>
                                            <!-- Card content -->
                                            <StackPanel>
                                                <!-- Category as a chip -->
                                                <Border  Background="#FFF9C4"
     CornerRadius="12"
     Padding="4,1"
     Margin="0,0,0,8"
     HorizontalAlignment="Left" Visibility="Collapsed">
                                                    <!--Visibility="{Binding Category, Converter={StaticResource NullToVisibilityConverter}}"-->
                                                    <!-->-->
                                                    <TextBlock Text="{Binding Category}" Foreground="#616161" FontWeight="SemiBold" FontSize="13"/>
                                                </Border>

                                                <!-- Title row with actions -->
                                                <DockPanel Margin="0,0,0,2">
                                                    <TextBlock Text="{Binding Title}"
          FontWeight="Bold"
          FontSize="17"
          DockPanel.Dock="Left"
          VerticalAlignment="Center"/>
                                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0,0,0">
                                                        <Button Style="{StaticResource MaterialDesignToolButton}"
         ToolTip="Edit"
         Click="EditNote_Click"
         Tag="{Binding}">
                                                            <materialDesign:PackIcon Kind="Pencil" Width="16" Height="16"/>
                                                        </Button>
                                                        <Button Style="{StaticResource MaterialDesignToolButton}"
         ToolTip="Delete"
         Click="DeleteNote_Click"
         Tag="{Binding}">
                                                            <materialDesign:PackIcon Kind="Delete" Width="16" Height="16"/>
                                                        </Button>
                                                    </StackPanel>
                                                </DockPanel>

                                                <!-- Divider -->
                                                <Separator Margin="0,4,0,8" Opacity="0.15"/>

                                                <!-- Content -->
                                                <TextBlock Text="{Binding Content}"
        TextWrapping="Wrap"
        FontSize="15"
        Foreground="#222"
        Margin="0,0,0,4"
        MaxHeight="90"
        TextTrimming="CharacterEllipsis"/>
                                                <!-- Date/time at bottom -->
                                                <DockPanel Margin="0,10,0,0">
                                                    <materialDesign:PackIcon Kind="Clock" Width="14" Height="14" DockPanel.Dock="Left" Margin="0,0,6,0" Foreground="#757575"/>
                                                    <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:hh:mm tt, ddd d MMM}'}"
          Foreground="#757575"
          FontSize="12"
          VerticalAlignment="Center"/>
                                                </DockPanel>
                                            </StackPanel>
                                        </materialDesign:Card>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>


                        </WrapPanel>

                    </ScrollViewer>
                </Grid>

               

               
               

            </Grid>
        </Border>
    </Grid>
</Window>

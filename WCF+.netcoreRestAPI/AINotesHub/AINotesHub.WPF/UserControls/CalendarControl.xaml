<UserControl x:Class="AINotesHub.WPF.UserControls.CalendarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AINotesHub.WPF.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Border Background="White"
            CornerRadius="12"
            Padding="15"
            Margin="5"
            Effect="{DynamicResource ShadowEffect}">

            <StackPanel>

                <TextBlock Text="Calendar"
                       FontWeight="Bold"
                       FontSize="22"
                       Margin="0 0 0 15"/>

                <!-- Actual Calendar Control -->
                <Calendar x:Name="CustomCalendar"
                      SelectionMode="SingleDate"
                      DisplayDateStart="2020-01-01"
                      DisplayDateEnd="2030-12-31"
                      BorderThickness="0"/>
            </StackPanel>

        </Border>
    </Grid>
</UserControl>

<UserControl x:Class="AINotesHub.WPF.UserControls.SessionExpiredControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AINotesHub.WPF.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Width="350" Height="180" Margin="15">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

            <TextBlock Text="Session expired"
                       FontSize="20"
                       FontWeight="Bold"
                       TextAlignment="Center"/>

            <TextBlock Text="Please login again."
                       Margin="0 10"
                       TextAlignment="Center"/>

            <Button Content="OK"
                    Width="100"
                    Margin="0 20 0 0"
                    HorizontalAlignment="Center"
                    Click="BtnOk_Click"/>

        </StackPanel>
    </Grid>
</UserControl>

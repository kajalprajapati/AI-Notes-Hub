<UserControl x:Class="AINotesHub.WPF.Views.SidebarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AINotesHub.WPF.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:AINotesHub.WPF.Converters"
                          xmlns:views="clr-namespace:AINotesHub.WPF.Views"

x:Name="RootWindow"
             mc:Ignorable="d" 
             d:DesignHeight="450" 
             d:DesignWidth="800">
    <UserControl.Resources>


        <!--<converters:HexToBrushConverter x:Key="HexToBrushConverter"/>-->

        <converters:SelectedBorderConverter x:Key="SelectedBorderConverter"
                                   SelectedBrush="#FF6200EE"
                                   UnselectedBrush="Transparent"/>
    </UserControl.Resources>

    <!--<DockPanel>-->
    <Grid Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <!-- 0: Add new (TextBlock) -->
            <RowDefinition Height="auto"/>
            <!-- 1: Ellipses -->
            <RowDefinition Height="auto"/>
            <!-- 2: Buttons (Calendar, Archive, Trash) -->
            <RowDefinition Height="*"/>
            <!-- 3: CalendarHost (fills remaining space) -->
            <RowDefinition Height="auto"/>
            <!-- 4: Bottom StackPanel (Upgrade Pro) -->
            <RowDefinition Height="auto"/>
            <!-- 5: NEW: User Profile and settings Header -->
            <RowDefinition Height="Auto"/>
            <!-- 5: User Profile and settings Header pinned bottom -->
        </Grid.RowDefinitions>

        <!-- Add new -->
        <TextBlock Grid.Row="0" Visibility="Collapsed" Foreground="Black" FontSize="18" Text="Add new" FontWeight="SemiBold" Margin="5 5 0 10"/>

        <!-- Ellipses -->
        <StackPanel  Visibility="Visible" Grid.Row="2" Orientation="Horizontal"  Margin="0,0,0,0">
            <!--<ScrollViewer Grid.Row="1">-->
            <StackPanel Orientation="Vertical" HorizontalAlignment="Left" Margin="20">

                <TextBlock Text="Choose Color" 
               FontSize="14" 
               FontWeight="SemiBold" 
               Foreground="#555555" 
               Margin="0,0,0,8"/>

                <ToggleButton x:Name="ColorPickerButton" Content="Color Selected"
              IsChecked="{Binding IsColorSelected, Mode=TwoWay}"
                  Width="44" Height="44"
                  Background="Transparent"
                  BorderThickness="0"
                  HorizontalAlignment="Left" 
                                            Command="{Binding SelectColorCommand}"
                                            CommandParameter="{Binding DataContext.CurrentNoteColorHex, ElementName=RootWindow}">



                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Grid x:Name="Root" Cursor="Hand">
                                <Ellipse Stroke="#9C27B0"  StrokeThickness="2" Fill="White"/>

                                <Ellipse Width="34" Height="34" 
                             HorizontalAlignment="Center" 
                             VerticalAlignment="Center" 

                                    Fill="{Binding DataContext.CurrentNoteColorHex, ElementName=RootWindow}">
                                    <!--Fill="{Binding Converter={StaticResource HexToBrushConverter}}">-->
                                    <Ellipse.InputBindings>
                                        <MouseBinding Gesture="LeftClick"
                                  Command="{Binding DataContext.SelectColorCommand,
                                           ElementName=RootWindow}"
                                                            CommandParameter="{Binding DataContext.CurrentNoteColorHex, ElementName=RootWindow}" />

                                    </Ellipse.InputBindings>

                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.1"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <!--<Path Data="M 0 0 L 4 4 L 8 0" 
                              Stroke="Gray" 
                              VerticalAlignment="Bottom" 
                              HorizontalAlignment="Right" 
                              Margin="0,0,5,8"/>-->
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Opacity" Value="0.8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>

                <Popup IsOpen="{Binding IsChecked, ElementName=ColorPickerButton}" 
           StaysOpen="False" 
           AllowsTransparency="True" 
           PlacementTarget="{Binding ElementName=ColorPickerButton}"
           Placement="Bottom"
           VerticalOffset="8" MaxHeight="320" >

                    <Border Background="White" 
                CornerRadius="16" 
                Padding="12" 
                BorderBrush="#EEEEEE" 
                BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="8" Opacity="0.15"/>
                        </Border.Effect>

                        <!-- 👇 FIX: Grid instead of StackPanel -->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <!-- Title -->
                                <RowDefinition Height="*"/>
                                <!-- ListBox -->
                            </Grid.RowDefinitions>

                            <TextBlock Text="Select a shade" FontSize="11" Foreground="Gray" Margin="5,0,0,10"/>

                            <ListBox Grid.Row="1" ItemsSource="{Binding NoteColors}"
                         SelectedItem="{Binding CurrentNoteColorHex, Mode=TwoWay}"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                         Width="240">
                                <ListBox.Resources>
                                    <Style TargetType="ScrollBar"
               BasedOn="{StaticResource MaterialDesignScrollBar}" x:Key="MyMaterialScrollBar">
                                        <!-- Optional tweaks -->
                                        <Setter Property="Width" Value="50"/>
                                        <Setter Property="Margin" Value="2"/>
                                    </Style>
                                </ListBox.Resources>

                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" IsItemsHost="True" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="ToolTip" Value="{Binding}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Grid Width="40" Height="48" Background="Transparent" Cursor="Hand">
                                                        
                                                        <Ellipse x:Name="SelectionRing" Stroke="#7B61FF" StrokeThickness="2.5" Width="40" Height="40" Opacity="0"/>

                                                        <Ellipse x:Name="WhiteGap" Fill="White" Width="34" Height="34" Opacity="0"/>

                                                        <Ellipse x:Name="ColorCircle" Fill="{Binding}" Width="30" Height="30"/>

                                                        <Path x:Name="Checkmark"
                              Data="M 10,15 L 14,19 L 22,11"
                              Stroke="White"
                              StrokeThickness="2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Width="32" Height="32"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Opacity="0"/>
                                                    </Grid>

                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="SelectionRing" Property="Opacity" Value="1"/>
                                                            <Setter TargetName="WhiteGap" Property="Opacity" Value="1"/>
                                                            <Setter TargetName="Checkmark" Property="Opacity" Value="1"/>
                                                            <Setter TargetName="ColorCircle" Property="Width" Value="26"/>
                                                            <Setter TargetName="ColorCircle" Property="Height" Value="26"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <!--<ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="ToolTip" Value="{Binding}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Grid Width="48" Height="48" Background="Transparent" Cursor="Hand">
                                                        <Ellipse x:Name="SelectionRing" Stroke="#7B61FF" StrokeThickness="2.5" Width="40" Height="40" Opacity="0"/>
                                                        <Ellipse x:Name="WhiteGap" Fill="White" Width="34" Height="34" Opacity="0"/>
                                                        <Ellipse x:Name="ColorCircle" Fill="{Binding}" Width="30" Height="30"/>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="SelectionRing" Property="Opacity" Value="1"/>
                                                            <Setter TargetName="WhiteGap" Property="Opacity" Value="1"/>
                                                            <Setter TargetName="ColorCircle" Property="Width" Value="26"/>
                                                            <Setter TargetName="ColorCircle" Property="Height" Value="26"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>-->
                            </ListBox>
                        </Grid>
                    </Border>
                </Popup>


            </StackPanel>


            <!--</ScrollViewer>-->
            <!--<Ellipse Width="20" Height="20" Fill="Yellow"  Margin="5"/>-->

            <!--<StackPanel Visibility="Collapsed">
                <Button 
        Width="25" Height="25"
        Padding="0"
        BorderThickness="0"
        Margin="5"
        Background="Yellow" Style="{StaticResource CircleColorButton}"
>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Ellipse Fill="{TemplateBinding Background}"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button 
        Width="25" Height="25"
        Padding="0"
        BorderThickness="0"
        Margin="5"
        Background="Blue" Style="{StaticResource CircleColorButton}"
>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Ellipse Fill="{TemplateBinding Background}"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button
        Width="25" Height="25"
        Padding="0"
        BorderThickness="0"
        Margin="5"
        Background="Red" Style="{StaticResource CircleColorButton}"
>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Ellipse Fill="{TemplateBinding Background}"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>-->


        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,0,0,0">

            <!-- Calendar / Archive / Trash -->
            <!--<Button Grid.Row="0" Visibility="Collapsed" Content="Calendar" Name="BtnCalendar" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,0,5" Command="{Binding CalendarCommand}"/>-->
            <!--<Button Visibility="Collapsed" Grid.Row="1" Content="Archive"  Name="BtnArchive"  Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,0,5" Command="{Binding ArchiveCommand}"/>
            <Button Visibility="Collapsed" Grid.Row="2" Content="Trash"  Name="BtnTrash" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,0,5" Command="{Binding TrashCommand}"/>-->
            <!-- ➕ Add Note -->
            <Button Grid.Column="0" Visibility="Collapsed"
            Margin="12,8"
            Padding="14,6"
            Background="#3F51B5"
            Foreground="White"
            FontWeight="SemiBold"
            ToolTip="Add Note"
            >
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="NotePlusOutline" Width="18" Height="18" Margin="0,0,6,0"/>
                    <TextBlock Text="Add Note"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <ListView Grid.Row="3" 
Margin="0,20,10,0"
                  ItemContainerStyle="{StaticResource ModernListViewItemStyle}"
                  ItemsSource="{Binding NavigationItems}"
          SelectedItem="{Binding SelectedNavigationItem}"
          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                ScrollViewer.VerticalScrollBarVisibility="Auto"
    Background="Transparent"
          BorderThickness="1">


            <!--<ListView.ItemContainerStyle>
            </ListView.ItemContainerStyle>-->
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="{Binding Icon}" 
                                         Width="22" Height="22" 
                                         Margin="0,0,15,0" 
                                         VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Name}" 
                           FontSize="15" 
                           VerticalAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>


        <ContentControl Grid.Row="3" x:Name="CalendarHost"  Margin="0,10,0,0" />

        <!-- Upgrade Pro -->
        <StackPanel Grid.Row="4" VerticalAlignment="Bottom" Margin="0,50,0,0">
            <TextBlock Text="Want to access unlimited notes?" FontSize="12" TextWrapping="Wrap"/>
            <Button Content="Upgrade Pro" BorderThickness="1" Margin="0,5,0,0" Background="{DynamicResource UpdateButtonGradient}"
  Foreground="White"/>
        </StackPanel>

        <!-- Last row pinned at bottom -->
        <Grid Grid.Row="5">
            <ContentControl>
                <views:ProfileImageView/>
            </ContentControl>
            <!--<ContentControl x:Name="ProfileImageContent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" 
                            Content="{Binding CurrentContent}">
                <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type vm:ProfileImageViewModel}">
                        <TextBlock Text="TEMPLATE FOUND" FontSize="30"/>
                    </DataTemplate>
                </ContentControl.Resources>
            </ContentControl>-->
            <!--<ContentControl Content="{Binding CurrentContent}">
                <ContentControl.ContentTemplate>
                    <DataTemplate>
                        <TextBlock Text="IT RENDERS" FontSize="30"/>
                    </DataTemplate>
                </ContentControl.ContentTemplate>
            </ContentControl>-->
            <!--<views-->
        </Grid>

        <!--</StackPanel>-->
    </Grid>
</UserControl>

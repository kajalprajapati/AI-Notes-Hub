<UserControl x:Class="AINotesHub.WPF.Views.Sidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AINotesHub.WPF.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <StackPanel Margin="10">
            <!-- Add new -->
            <TextBlock Text="Add new" FontWeight="Bold" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <Ellipse Width="20" Height="20" Fill="Yellow" Margin="5"/>
                <Ellipse Width="20" Height="20" Fill="Blue" Margin="5"/>
                <Ellipse Width="20" Height="20" Fill="Red" Margin="5"/>
            </StackPanel>

            <!-- Calendar / Archive / Trash -->
            <Button Content="Calendar" Margin="0,0,0,5"/>
            <Button Content="Archive" Margin="0,0,0,5"/>
            <Button Content="Trash" Margin="0,0,0,5"/>

            <!-- Upgrade Pro -->
            <StackPanel VerticalAlignment="Bottom" Margin="0,50,0,0">
                <TextBlock Text="Want to access unlimited notes?" FontSize="12" TextWrapping="Wrap"/>
                <Button Content="Upgrade Pro" Margin="0,5,0,0" Background="#2D5BFF" Foreground="White"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>

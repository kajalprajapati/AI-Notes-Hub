{
    "ConnectionStrings": {
        //"DefaultConnection": "Server=localhost;Database=AINotesHubDB;Trusted_Connection=True;MultipleActiveResultSets=true"
        "DefaultConnection": "Data Source=(localdb)\\MSSQLLocalDB;Initial Catalog=AINotesHubDB;Integrated Security=True;Connect Timeout=30;Encrypt=False;Trust Server Certificate=False;Application Intent=ReadWrite;Multi Subnet Failover=False"

    },

    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "Serilog": {
        "Using": [ "Serilog.Sinks.File", "Serilog.Sinks.MSSqlServer" ],
        "MinimumLevel": "Information",
        "WriteTo": [
            {
                "Name": "File",
                "Args": {
                    "path": "Logs/AINotesHub.API.txt",//Store logs in Logs folder with this file Name
                    "rollingInterval": "Day",
                    "retainedFileCountLimit": 7 //Keeps 7 days of logs (auto deletes old ones)
                    //"formatter": "Serilog.Formatting.Compact.CompactJsonFormatter"
                }
            },
            {
                "Name": "MSSqlServer",
                "Args": {
                    "connectionString": "DefaultConnection",
                    "tableName": "Logs",
                    "autoCreateSqlTable": true
                }
            }
        ],
        "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
        "Properties": {
            "Application": "AINotesHub.API"
        }
    },

    "Jwt": {
        "SecretKey": "SuperSecretKey12345!",
        "Issuer": "AINotesHub",
        "Audience": "AINotesHubUsers",
        "ExpiryMinutes": 1440 //Example:User logs in at 4:00 PMToken expiry = 5 minutesUser’s token becomes invalid at 4:05 PM.After that:User cannot access APIsThe system returns 401 – UnauthorizedUser must login again
    },

    "AllowedHosts": "*"
}